APP_ENV=staging
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://staging.your-frontend-domain.com
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ecommerce_analytics_staging
REDIS_URL=redis://redis:6379
ACCESS_TOKEN_SECRET=replace-with-strong-staging-access-secret-min-32-chars
REFRESH_TOKEN_SECRET=replace-with-strong-staging-refresh-secret-min-32-chars
ACCESS_TOKEN_EXPIRES_IN_MINUTES=15
REFRESH_TOKEN_EXPIRES_IN_DAYS=7
