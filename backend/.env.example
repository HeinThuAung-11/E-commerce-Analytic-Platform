APP_ENV=local
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_analytics
REDIS_URL=redis://localhost:6379
ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters-for-access-token
REFRESH_TOKEN_SECRET=replace-with-at-least-32-characters-for-refresh-token
ACCESS_TOKEN_EXPIRES_IN_MINUTES=15
REFRESH_TOKEN_EXPIRES_IN_DAYS=7
