NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ecommerce_analytics
REDIS_URL=redis://redis:6379
ACCESS_TOKEN_SECRET=replace-with-a-strong-random-secret-at-least-32-characters
